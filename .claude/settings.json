{
  "model": "claude-sonnet-5",
  "permissions": {
    "allow": [
      "Bash(npm run:*)",
      "Bash(npm install:*)",
      "Bash(npm list:*)",
      "Bash(git status:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/migration-check-session.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/migration-post-write.sh"
          },
          {
            "type": "command",
            "command": "bash hooks/agent-security-on-auth.sh"
          },
          {
            "type": "command",
            "command": "bash hooks/agent-architect-on-new-module.sh"
          },
          {
            "type": "command",
            "command": "bash hooks/agent-qa-on-crud.sh"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/migration-post-write.sh"
          },
          {
            "type": "command",
            "command": "bash hooks/agent-security-on-auth.sh"
          },
          {
            "type": "command",
            "command": "bash hooks/agent-qa-on-crud.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/migration-validator.sh"
          },
          {
            "type": "command",
            "command": "bash hooks/agent-reviewer-on-commit.sh"
          },
          {
            "type": "command",
            "command": "bash hooks/agent-optimizer-on-build.sh"
          },
          {
            "type": "command",
            "command": "bash hooks/agent-docs-on-feature.sh"
          },
          {
            "type": "command",
            "command": "bash hooks/agent-deploy-on-push.sh"
          }
        ]
      }
    ]
  }
}
